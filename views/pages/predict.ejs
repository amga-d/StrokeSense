<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Stroke Risk Prediction - StrokeSense</title>
    <meta name="description"
        content="Get your personalized stroke risk assessment with StrokeSense's AI-powered prediction tool.">

    <!-- CSS Files -->
    <link rel="stylesheet" href="/css/views/predict.css">

    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <!-- Favicon -->
    <link rel="icon" href="/assets/favicon.ico" type="image/x-icon">
</head>

<body>
    <!-- Include Header Component -->
    <div id="header-container">
        <%- include('../partials/Header')-%>
    </div>

    <!-- Main Content -->
    <main>
        <!-- Page Title -->
        <section class="page-header">
            <div class="container">
                <h1>Stroke Risk Assessment</h1>
                <p>Fill in your information to receive a personalized risk evaluation</p>
            </div>
        </section>

        <!-- Include Prediction Form Component -->
        <div id="predict-form-container">
            <%- include('../partials/PredictForm')-%>
        </div>

        <!-- Include Display Result Component -->
        <div id="display-result-container">
            <%- include('../partials/DisplayResult')-%>
        </div>
    </main>

    <!-- Include Footer Component -->
    <div id="footer-container">
        <%- include('../partials/Footer') -%>
    </div>

    <!-- Import the JavaScript controller -->
    <script src="/js/predict.js"></script>
</body>

</html>